    {
      "id": "permissions",
      "name": "File Permission",
      "info": {
        "summary": [
          "প্রতিটি file/directory-র permission তিন ভাগে: owner, group, others — প্রতিটিতে r (read), w (write), x (execute)।",
          "Octal: r=4, w=2, x=1। যেমন 755 = rwx r-x r-x; 644 = rw- r-- r--।",
          "chmod = permission বদলায়, chown = owner বদলায়, umask = নতুন file-এর default permission ঠিক করে।"
        ],
        "table": {
          "headers": ["Octal", "মানে", "সাধারণ ব্যবহার"],
          "rows": [
            ["755", "rwx r-x r-x", "script, directory"],
            ["644", "rw- r-- r--", "সাধারণ file"],
            ["600", "rw- --- ---", "private file (যেমন SSH key)"],
            ["777", "rwx rwx rwx", "সবার সব access (ঝুঁকিপূর্ণ)"]
          ]
        }
      },
      "commands": [
        { "cmd": "ls -l", "desc": "file-এর permission দেখা" },
        { "cmd": "chmod 755 file.sh", "desc": "octal দিয়ে permission সেট" },
        { "cmd": "chmod +x script.sh", "desc": "execute permission যোগ" },
        { "cmd": "chmod -R 755 /var/www", "desc": "recursive permission (directory ও ভেতরের সব)" },
        { "cmd": "chown john file.txt", "desc": "owner বদলানো" },
        { "cmd": "chown john:dev file.txt", "desc": "owner ও group বদলানো" },
        { "cmd": "umask", "desc": "default permission mask দেখা" },
        { "cmd": "find /home -type f -perm 777", "desc": "777 permission-যুক্ত file খোঁজা" }
      ],
      "practice": [
        { "prompt": "file.sh-এ permission দাও: owner=rwx, group=r-x, others=r-x (octal)", "accept": ["chmod 755 file.sh"], "explain": "rwx=7, r-x=5 → 755" },
        { "prompt": "script.sh file-এ execute permission যোগ করো", "accept": ["chmod +x script.sh"], "explain": "+x = execute যোগ" },
        { "prompt": "file.txt-এর owner john বানাও", "accept": ["chown john file.txt", "sudo chown john file.txt"], "explain": "chown <owner> <file>" },
        { "prompt": "file.txt-এর owner john ও group dev বানাও", "accept": ["chown john:dev file.txt", "sudo chown john:dev file.txt"], "explain": "chown owner:group file" },
        { "prompt": "data.txt-এ owner, group ও others সবাইকে read+write দাও (octal)", "accept": ["chmod 666 data.txt"], "explain": "rw-=6 → 666" },
        { "prompt": "বর্তমান umask মান দেখাও", "accept": ["umask"], "explain": "umask = default permission mask" },
        { "prompt": "/var/www ও তার ভেতরের সব কিছুতে recursive ভাবে 755 permission দাও", "accept": ["chmod -R 755 /var/www", "sudo chmod -R 755 /var/www"], "explain": "-R = recursive" },
        { "prompt": "/home-এর ভেতরে 777 permission-যুক্ত file গুলো খুঁজে বের করো", "accept": ["find /home -type f -perm 777", "find /home -perm 777 -type f"], "explain": "find -perm দিয়ে permission-ভিত্তিক খোঁজা" }
      ]
    },
